{
  "name": "@cards-against-jewels/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "prebuild": "npm run build --workspace @cards-against-jewels/shared",
    "pretest": "npm run build --workspace @cards-against-jewels/shared",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@cards-against-jewels/shared": "file:../../packages/shared",
    "@fastify/cors": "^10.1.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.2",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.18.8",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
