# Docker Compose production variables.
# Copy this file to `.env.production` on the VPS and change every secret.

POSTGRES_DB=caj
POSTGRES_USER=caj
POSTGRES_PASSWORD=change_me_use_a_strong_password

# If POSTGRES_PASSWORD contains reserved URL characters such as @, :, /, ?, #,
# encode them in DATABASE_URL.
DATABASE_URL=postgresql://caj:change_me_use_a_strong_password@postgres:5432/caj?schema=public

VITE_SERVER_URL=https://api.example.com
VITE_DISCORD_CLIENT_ID=
